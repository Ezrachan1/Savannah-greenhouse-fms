# ===========================================
# FARM MANAGEMENT SYSTEM - Environment Config
# ===========================================
# Copy this file to .env and update values

# ----- Server Configuration -----
NODE_ENV=development
PORT=5000

# ----- Database Configuration -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farm_management_system
DB_USER=postgres
DB_PASSWORD=your_password_here

# ----- JWT Configuration -----
JWT_SECRET=your_super_secure_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ----- KRA eTIMS Configuration -----
# These will be provided by KRA after eTIMS registration
ETIMS_API_URL=https://etims.kra.go.ke/api/v1
ETIMS_DEVICE_ID=your_device_id
ETIMS_TIN=your_kra_pin
ETIMS_BRANCH_ID=00
ETIMS_PRIVATE_KEY_PATH=./certs/etims_private.key
ETIMS_CERTIFICATE_PATH=./certs/etims_cert.pem

# ----- Company Information -----
COMPANY_NAME=Savannah Propagation Nursery
COMPANY_ADDRESS=Mogotio Town, Nakuru County
COMPANY_PHONE=+254700000000
COMPANY_EMAIL=info@savannahpropagation.co.ke
COMPANY_KRA_PIN=P000000000X

# ----- File Upload Configuration -----
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----- Logging -----
LOG_LEVEL=debug
LOG_FILE_PATH=./logs
